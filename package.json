{
  "name": "saegim",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; pnpm -r --parallel dev",
    "dev:web": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; pnpm --filter @saegim/web dev",
    "dev:api": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; pnpm --filter @saegim/api start:dev",
    "db:generate": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; pnpm --filter @saegim/api db:generate",
    "db:push": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; pnpm --filter @saegim/api db:push",
    "db:validate": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; pnpm --filter @saegim/api db:validate",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.3"
  }
}
