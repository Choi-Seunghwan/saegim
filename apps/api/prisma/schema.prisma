generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VerificationState {
  NONE
  OFFICIAL
}

enum PostVisibility {
  PUBLIC
  PRIVATE
}

enum PostCreationType {
  ORIGINAL
  CURATION
}

enum PostPlacementSurface {
  HOME
  SHELF
}

enum PostPlacementSlot {
  HERO
  TODAY_RAIL
  EDITOR_PICK
}

enum SourceKind {
  BOOK
  WEB
  DIRECT
  PUBLISHER
}

enum EmbeddingStatus {
  PENDING
  READY
  SKIPPED
}

enum OAuthProvider {
  GOOGLE
  KAKAO
  NAVER
}

enum EditorialPageKind {
  NOTICE
  EVENT
  AD
}

enum EditorialCtaAction {
  DISCOVER
  CONTACT
}

enum LegalDocumentType {
  TERMS
  PRIVACY
}

enum ConsentSource {
  EMAIL_SIGNUP
  GOOGLE_OAUTH
}

model Account {
  id                 String            @id @default(cuid())
  handle             String            @unique
  email              String?           @unique
  displayName        String
  photoUrl           String?
  tagline            String            @default("")
  bio                String?
  verification       VerificationState @default(NONE)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  posts              Post[]            @relation("PostAuthor")
  oauthAccounts      OAuthAccount[]
  emailCredential    EmailCredential?
  followerRelations  Follow[]          @relation("FollowFollowing")
  followingRelations Follow[]          @relation("FollowFollower")
  likes              Like[]
  carves             Carve[]
  comments           Comment[]
  consents           AccountConsent[]

  @@index([verification])
  @@index([createdAt])
}

model EmailCredential {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  accountId    String   @unique
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model OAuthAccount {
  id                String        @id @default(cuid())
  provider          OAuthProvider
  providerAccountId String
  email             String?
  accountId         String
  account           Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([provider, providerAccountId])
  @@index([accountId])
}

model AccountConsent {
  id           String            @id @default(cuid())
  accountId    String
  account      Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  documentType LegalDocumentType
  version      String
  source       ConsentSource
  agreedAt     DateTime          @default(now())
  createdAt    DateTime          @default(now())

  @@unique([accountId, documentType, version])
  @@index([accountId, documentType])
}

model Post {
  id                String           @id @default(cuid())
  title             String
  authorId          String
  author            Account          @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  visibility        PostVisibility   @default(PUBLIC)
  creationType      PostCreationType @default(ORIGINAL)
  likeCountCache    Int              @default(0)
  commentCountCache Int              @default(0)
  publishedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  cards             Card[]
  likes             Like[]
  carves            Carve[]
  comments          Comment[]
  placements        PostPlacement[]

  @@index([authorId, createdAt])
  @@index([visibility, publishedAt])
}

model PostPlacement {
  id        String               @id @default(cuid())
  postId    String
  post      Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  surface   PostPlacementSurface
  slot      PostPlacementSlot
  priority  Int                  @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([postId, surface, slot])
  @@index([surface, slot, isActive, priority])
  @@index([postId])
}

model Card {
  id              String          @id @default(cuid())
  postId          String
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  order           Int
  text            String
  comp            Json
  sourceKind      SourceKind      @default(DIRECT)
  sourceAuthor    String?
  sourceWork      String?
  sourceUrl       String?
  tags            String[]        @default([])
  embeddingStatus EmbeddingStatus @default(PENDING)
  embedding       Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  carves          Carve[]

  @@unique([postId, order])
  @@index([postId])
  @@index([embeddingStatus])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    Account  @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   Account  @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Like {
  id        String   @id @default(cuid())
  accountId String
  postId    String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([accountId, postId])
  @@index([postId])
}

model Carve {
  id        String   @id @default(cuid())
  accountId String
  postId    String
  cardId    String?
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  card      Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@unique([accountId, postId])
  @@index([postId])
  @@index([cardId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    Account  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([authorId])
}

model EditorialPage {
  id          String              @id @default(cuid())
  kind        EditorialPageKind
  label       String
  title       String
  summary     String              @default("")
  body        String[]            @default([])
  ctaLabel    String?
  ctaAction   EditorialCtaAction?
  publishedAt DateTime
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([kind, isActive, publishedAt])
}
