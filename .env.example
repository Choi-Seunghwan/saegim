# 새김 공통
NODE_ENV=development

# 웹
# 로컬 OAuth에서는 콜백·웹·API 호스트를 하나로 맞춘다.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000

# 분석(Mixpanel). 로컬 기본은 끄고, 운영/스테이징에서 토큰과 enabled를 함께 설정한다.
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_MIXPANEL_ENABLED=false
NEXT_PUBLIC_MIXPANEL_DEBUG=false
# NEXT_PUBLIC_MIXPANEL_API_HOST=

# API
API_PORT=4000
WEB_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
DATABASE_URL=postgresql://saegim:saegim@localhost:55432/saegim
SAEGIM_SESSION_SECRET=change-me-in-production

# 이미지 업로드(S3 또는 S3 호환 저장소)
# AWS SDK 기본 인증/리전. 운영에서는 IAM 사용자보다 업로드 전용 역할/키를 권장한다.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# 앱 업로드 설정. public base URL은 CloudFront나 S3 public endpoint 중 실제 노출 주소를 넣는다.
SAEGIM_S3_BUCKET=
SAEGIM_S3_PUBLIC_BASE_URL=
SAEGIM_S3_PREFIX=uploads
# S3 호환 저장소(NCP Object Storage 등)를 쓸 때만 설정한다.
SAEGIM_S3_ENDPOINT=
SAEGIM_S3_FORCE_PATH_STYLE=false
SAEGIM_UPLOAD_MAX_BYTES=10485760

# Google OAuth 우선. 카카오/네이버는 provider 추상화 뒤 추가.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://127.0.0.1:4000/auth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=http://127.0.0.1:3000

# 업로드/CDN
AWS_REGION=ap-northeast-2
SAEGIM_UPLOADS_BUCKET=saegim-uploads-prod
SAEGIM_UPLOADS_CDN_BASE_URL=https://cdn.saegim.chuz.dev
