# 새김 공통
NODE_ENV=development

# 웹
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000
DATABASE_URL=postgresql://saegim:saegim@localhost:5432/saegim

# Google OAuth 우선. 카카오/네이버는 provider 추상화 뒤 추가.
