# 새김 공통
NODE_ENV=development

# 웹
# 로컬 OAuth에서는 콜백·웹·API 호스트를 하나로 맞춘다.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000

# API
API_PORT=4000
WEB_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
DATABASE_URL=postgresql://saegim:saegim@localhost:55432/saegim
SAEGIM_SESSION_SECRET=change-me-in-production

# Google OAuth 우선. 카카오/네이버는 provider 추상화 뒤 추가.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://127.0.0.1:4000/auth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=http://127.0.0.1:3000
